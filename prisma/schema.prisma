generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String         @db.VarChar(100)
  parentId  String?        @map("parent_id") @db.Uuid
  type      String         @default("department") @db.VarChar(20)
  status    String         @default("active") @db.VarChar(20)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime?      @map("deleted_at") @db.Timestamptz(6)
  parent    Organization?  @relation("OrganizationHierarchy", fields: [parentId], references: [id])
  children  Organization[] @relation("OrganizationHierarchy")
  users     User[]
  goals     Goal[]

  @@map("organizations")
}

model Role {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(50)
  permissions Json      @default("[]")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  users       User[]

  @@map("roles")
}

model User {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String        @map("org_id") @db.Uuid
  roleId       String        @map("role_id") @db.Uuid
  name         String        @db.VarChar(50)
  email        String        @db.VarChar(100)
  phone        String?       @db.VarChar(20)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  status       String        @default("active") @db.VarChar(20)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz(6)
  organization Organization  @relation(fields: [orgId], references: [id])
  role         Role          @relation(fields: [roleId], references: [id])
  ownedGoals   Goal[]        @relation("GoalOwner")
  revisedForecasts Forecast[] @relation("ForecastRevisedBy")
  ownedPlans   Plan[]        @relation("PlanOwner")
  approvedPlans Plan[]       @relation("PlanApprover")
  ownedTasks   Task[]        @relation("TaskOwner")
  feedbacks    Feedback[]
  exceptions   Exception[]

  @@index([orgId])
  @@index([roleId])
  @@map("users")
}

model Goal {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId        String    @map("org_id") @db.Uuid
  ownerId      String    @map("owner_id") @db.Uuid
  parentId     String?   @map("parent_id") @db.Uuid
  title        String    @db.VarChar(200)
  metric       String?   @db.VarChar(100)
  targetValue  Decimal?  @map("target_value") @db.Decimal
  currentValue Decimal?  @default(0) @map("current_value") @db.Decimal
  startDate    DateTime  @map("start_date") @db.Date
  deadline     DateTime  @db.Date
  status       String    @default("draft") @db.VarChar(20)
  version      Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  organization Organization @relation(fields: [orgId], references: [id])
  owner        User      @relation("GoalOwner", fields: [ownerId], references: [id])
  parent       Goal?     @relation("GoalHierarchy", fields: [parentId], references: [id])
  children     Goal[]    @relation("GoalHierarchy")
  problems     Problem[]
  tasks        Task[]

  @@index([ownerId])
  @@map("goals")
}

model Problem {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  goalId      String?    @map("goal_id") @db.Uuid
  title       String     @db.VarChar(200)
  description String?
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)
  goal        Goal?      @relation(fields: [goalId], references: [id])
  decisionCases DecisionCase[]

  @@map("problems")
}

model DecisionCase {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  problemId   String       @map("problem_id") @db.Uuid
  title       String       @db.VarChar(200)
  stage       String       @default("dismantle") @db.VarChar(20)
  status      String       @default("open") @db.VarChar(20)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)
  problem     Problem      @relation(fields: [problemId], references: [id])
  hypotheses  Hypothesis[]
  forecasts   Forecast[]
  evaluations Evaluation[]
  roiSimulations RoiSimulation[]
  plans       Plan[]

  @@map("decision_cases")
}

model Hypothesis {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId         String     @map("case_id") @db.Uuid
  content        String
  evidenceScore  Decimal?   @map("evidence_score") @db.Decimal(5, 2)
  confidence     Decimal?   @db.Decimal(5, 2)
  counterExample String?    @map("counter_example")
  status         String     @default("proposed") @db.VarChar(20)
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?  @map("deleted_at") @db.Timestamptz(6)
  decisionCase   DecisionCase @relation(fields: [caseId], references: [id])

  @@map("hypotheses")
}

model Forecast {
  id                 String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId             String       @map("case_id") @db.Uuid
  version            Int
  inputHypothesisIds String[]     @default([]) @map("input_hypothesis_ids") @db.Uuid
  scenarios          Json
  modelSource        String       @map("model_source") @db.VarChar(50)
  confidence         Decimal?     @db.Decimal(5, 2)
  revisedBy          String?      @map("revised_by") @db.Uuid
  agentRunId         String?      @map("agent_run_id") @db.Uuid
  createdAt          DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?    @map("deleted_at") @db.Timestamptz(6)
  decisionCase       DecisionCase @relation(fields: [caseId], references: [id])
  revisedByUser      User?        @relation("ForecastRevisedBy", fields: [revisedBy], references: [id])

  @@unique([caseId, version], map: "uq_forecast_case_ver")
  @@map("forecasts")
}

model Evaluation {
  id               String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId           String       @map("case_id") @db.Uuid
  resourceScore    Decimal?     @map("resource_score") @db.Decimal(5, 2)
  timeScore        Decimal?     @map("time_score") @db.Decimal(5, 2)
  riskScore        Decimal?     @map("risk_score") @db.Decimal(5, 2)
  feasibilityScore Decimal?     @map("feasibility_score") @db.Decimal(5, 2)
  comment          String?
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz(6)
  decisionCase     DecisionCase @relation(fields: [caseId], references: [id])

  @@map("evaluations")
}

model RoiSimulation {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId        String       @map("case_id") @db.Uuid
  cost          Decimal      @db.Decimal
  revenue       Decimal      @db.Decimal
  roi           Decimal?     @db.Decimal
  paybackDays   Int?         @map("payback_days")
  assumptions   Json?
  createdAt     DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?    @map("deleted_at") @db.Timestamptz(6)
  decisionCase  DecisionCase @relation(fields: [caseId], references: [id])

  @@map("roi_simulations")
}

model Plan {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  caseId         String       @map("case_id") @db.Uuid
  ownerId        String       @map("owner_id") @db.Uuid
  title          String       @db.VarChar(200)
  description    String?
  status         String       @default("draft") @db.VarChar(20)
  submittedAt    DateTime?    @map("submitted_at") @db.Timestamptz(6)
  approvedBy     String?      @map("approved_by") @db.Uuid
  approvedAt     DateTime?    @map("approved_at") @db.Timestamptz(6)
  rejectedReason String?      @map("rejected_reason")
  version        Int          @default(0)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime?    @map("deleted_at") @db.Timestamptz(6)
  decisionCase   DecisionCase @relation(fields: [caseId], references: [id])
  owner          User         @relation("PlanOwner", fields: [ownerId], references: [id])
  approver       User?        @relation("PlanApprover", fields: [approvedBy], references: [id])
  tasks          Task[]

  @@map("plans")
}

model Standard {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title     String    @db.VarChar(200)
  content   String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  tasks     Task[]

  @@map("standards")
}

model Task {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  planId      String     @map("plan_id") @db.Uuid
  goalId      String?    @map("goal_id") @db.Uuid
  ownerId     String     @map("owner_id") @db.Uuid
  standardId  String?    @map("standard_id") @db.Uuid
  title       String     @db.VarChar(200)
  description String?
  dueTime     DateTime   @map("due_time") @db.Timestamptz(6)
  status      String     @default("todo") @db.VarChar(20)
  version     Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?  @map("deleted_at") @db.Timestamptz(6)
  plan        Plan       @relation(fields: [planId], references: [id])
  goal        Goal?      @relation(fields: [goalId], references: [id])
  owner       User       @relation("TaskOwner", fields: [ownerId], references: [id])
  standard    Standard?  @relation(fields: [standardId], references: [id])
  feedbacks   Feedback[]

  @@map("tasks")
}

model Feedback {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId       String     @map("task_id") @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  todayGoal    String?    @map("today_goal")
  result       String?
  blocker      String?
  nextAction   String?    @map("next_action")
  qualityScore Decimal?   @map("quality_score") @db.Decimal(5, 2)
  businessDate DateTime   @map("business_date") @db.Date
  revision     Int        @default(1)
  supersededBy String?    @map("superseded_by") @db.Uuid
  submittedAt  DateTime   @default(now()) @map("submitted_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @default(now()) @map("updated_at") @db.Timestamptz(6)
  task         Task       @relation(fields: [taskId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  supersededByFeedback Feedback?  @relation("FeedbackRevision", fields: [supersededBy], references: [id])
  supersedes   Feedback[] @relation("FeedbackRevision")

  @@map("feedbacks")
}

model Exception {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId   String?   @map("owner_id") @db.Uuid
  severity  String    @db.VarChar(20)
  status    String    @default("open") @db.VarChar(20)
  title     String    @db.VarChar(200)
  detail    String?
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)
  owner     User?     @relation(fields: [ownerId], references: [id])

  @@map("exceptions")
}

model AgentRun {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  agentType   String    @map("agent_type") @db.VarChar(30)
  triggerType String    @default("manual") @map("trigger_type") @db.VarChar(20)
  status      String    @default("running") @db.VarChar(20)
  input       Json?
  output      Json?
  toolCalls   Json?     @map("tool_calls")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("agent_runs")
}

model OutboxEvent {
  eventId        String    @id @default(dbgenerated("gen_random_uuid()")) @map("event_id") @db.Uuid
  eventType      String    @map("event_type") @db.VarChar(80)
  eventVersion   Int       @default(1) @map("event_version")
  aggregateType  String    @map("aggregate_type") @db.VarChar(50)
  aggregateId    String    @map("aggregate_id") @db.Uuid
  payload        Json
  status         String    @default("pending") @db.VarChar(20)
  attemptCount   Int       @default(0) @map("attempt_count")
  nextAttemptAt  DateTime  @default(now()) @map("next_attempt_at") @db.Timestamptz(6)
  lockedAt       DateTime? @map("locked_at") @db.Timestamptz(6)
  lockedBy       String?   @map("locked_by") @db.VarChar(80)
  publishedAt    DateTime? @map("published_at") @db.Timestamptz(6)
  lastError      String?   @map("last_error")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("outbox_events")
}

model OutboxConsumed {
  consumerName String   @map("consumer_name") @db.VarChar(80)
  eventId      String   @map("event_id") @db.Uuid
  consumedAt   DateTime @default(now()) @map("consumed_at") @db.Timestamptz(6)
  resultStatus String   @default("ok") @map("result_status") @db.VarChar(20)

  @@id([consumerName, eventId])
  @@map("outbox_consumed")
}

model IdempotencyKey {
  idempotencyKey     String    @id @map("idempotency_key") @db.VarChar(120)
  requestFingerprint String    @map("request_fingerprint") @db.VarChar(128)
  responseSnapshot   Json?     @map("response_snapshot")
  status             String    @default("in_progress") @db.VarChar(20)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt          DateTime  @map("expires_at") @db.Timestamptz(6)

  @@map("idempotency_keys")
}
